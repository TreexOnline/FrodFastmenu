{
  "name": "frodfast",
  "version": "1.0.1",
  "description": "FrodFast - Electron app for restaurant management",
  "main": "main.js",
  "homepage": "https://www.treexonline.online/",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "publish": "electron-builder --publish always",
    "dist": "npm run build"
  },
  "keywords": [
    "electron",
    "app",
    "restaurant",
    "menu",
    "frodfast"
  ],
  "author": "VictorTreex",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.frodfast.app",
    "productName": "FrodFast",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "VictorTreex",
        "repo": "app-FrodFast-eletron"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "compression": "maximum"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
