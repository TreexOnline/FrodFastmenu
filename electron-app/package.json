{
  "name": "frodfast",
  "version": "1.0.1",
  "description": "FrodFast - Electron app for restaurant management",
  "main": "main.js",
  "homepage": "https://www.treexonline.online/",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win --publish never",
    "dist": "npm run build",
    "publish": "electron-builder --win --publish always",
    "release": "npm run build && npm run publish"
  },
  "keywords": [
    "electron",
    "app",
    "restaurant",
    "menu",
    "frodfast"
  ],
  "author": {
    "name": "VictorTreex",
    "email": "support@treexonline.online"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.frodfast.app",
    "productName": "FrodFast",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FrodFast"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "VictorTreex",
        "repo": "app-FrodFast-eletron"
      }
    ],
    "compression": "maximum",
    "generateUpdatesFilesForAllChannels": true
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VictorTreex/app-FrodFast-eletron.git"
  }
}
